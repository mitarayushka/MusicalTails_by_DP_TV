<Application x:Class="MusicalTails.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Primary palette -->
        <Color x:Key="PrimaryColor">#5B7C99</Color>
        <Color x:Key="SecondaryColor">#7BA383</Color>
        <Color x:Key="BackgroundColor">#F0F2F5</Color>
        <Color x:Key="SurfaceColor">#FFFFFF</Color>
        <Color x:Key="TextColor">#2D3748</Color>
        <Color x:Key="TextLightColor">#FFFFFF</Color>
        <Color x:Key="AccentColor">#6B9BD1</Color>
        <Color x:Key="BorderColor">#D1D9E0</Color>
        <Color x:Key="ListSurfaceColor">#E8EDF2</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="{StaticResource TextLightColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="ListSurfaceBrush" Color="{StaticResource ListSurfaceColor}"/>
    </Application.Resources>
</Application>
